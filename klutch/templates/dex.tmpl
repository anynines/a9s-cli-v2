apiVersion: gateway.envoyproxy.io/v1alpha1
kind: EnvoyProxy
metadata:
  name: backend-envoy-proxy-config
  namespace: envoy-gateway-system
spec:
  provider:
    type: Kubernetes
    kubernetes:
      useListenerPortAsContainerPort: true
      envoyService:
        type: NodePort
        patch:
          type: StrategicMerge
          value:
            spec:
              ports:
              - name: http
                port: 8080
                targetPort: 8080
                nodePort: 30080
---
apiVersion: gateway.networking.k8s.io/v1
kind: GatewayClass
metadata:
  name: anynines-backend-envoy-gateway
spec:
  controllerName: gateway.envoyproxy.io/gatewayclass-controller
  parametersRef:
    group: gateway.envoyproxy.io
    kind: EnvoyProxy
    name: backend-envoy-proxy-config
    namespace: envoy-gateway-system
---
apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: anynines-backend-gateway
spec:
  gatewayClassName: anynines-backend-envoy-gateway
  listeners:
  - name: http
    protocol: HTTP
    port: 8080
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: dex-backend
spec:
  parentRefs:
  - name: anynines-backend-gateway
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /dex
    backendRefs:
    - name: dex
      port: 5556
---
apiVersion: v1
kind: Service
metadata:
  name: dex
spec:
  type: ClusterIP
  ports:
  - protocol: TCP
    name: dex
    port: 5556
    targetPort: 5556
  - protocol: TCP
    name: telemetry # Use this port for /healthz, /healthz/ready, /healthz/live
    port: 5558
    targetPort: 5558
  selector:
    app: dex
---
apiVersion: v1
kind: Secret
metadata:
  name: oidc-config
type: Opaque
stringData:
  oidc-issuer-client-id: "kube-bind"
  oidc-issuer-client-secret: "{{ .DexClientSecret }}"
  oidc-issuer-url: "http://{{ .Host }}:{{ .BackendExposurePort }}/dex"
  oidc-callback-url: "http://{{ .Host }}:{{ .BackendExposurePort }}/callback"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: dex-config
data:
  config: |
    issuer: http://{{ .Host }}:{{ .BackendExposurePort }}/dex

    storage:
      type: memory

    web:
      http: 0.0.0.0:5556

    telemetry:
      http: 0.0.0.0:5558

    grpc:
      addr: 0.0.0.0:5557

    staticClients:
      - idEnv: DEX_ISSUER_CLIENT_ID
        redirectURIs:
        - 'http://{{ .Host }}:{{ .BackendExposurePort }}/callback'
        name: 'Kube Bind'
        secretEnv: DEX_ISSUER_CLIENT_SECRET

    enablePasswordDB: true

    staticPasswords:
      - email: "admin@example.com"
        hash: "$2a$10$2b2cU8CPhOTaGrs1HRQuAueS7JTT5ZHsHSzYiFPm1leZck7Mc8T4W" # "password"
        username: "admin"
        userID: "08a8684b-db88-4b73-90a9-3cd1661f5466"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: dex
spec:
  selector:
    matchLabels:
      app: dex
  replicas: 1
  template:
    metadata:
      labels:
        app: dex
    spec:
      containers:
      - name: dex
        image: dexidp/dex:v2.42.0-distroless
        args:
        - dex
        - serve
        - /conf/dex/config
        resources:
          requests:
            cpu: 100m
            memory: 64Mi
          limits:
            cpu: 400m
            memory: 256Mi
        env:
        - name: DEX_ISSUER_CLIENT_SECRET
          valueFrom:
            secretKeyRef:
              name: oidc-config
              key: oidc-issuer-client-secret
        - name: DEX_ISSUER_CLIENT_ID
          valueFrom:
            secretKeyRef:
              name: oidc-config
              key: oidc-issuer-client-id
        ports:
        - containerPort: 5556
          name: dex
        volumeMounts:
        - name: data
          mountPath: /data
          readOnly: false
        - name: config
          mountPath: /conf/dex
          readOnly: true
      volumes:
      - name: config
        configMap:
          name: dex-config
      - name: data
        emptyDir: {}
---
